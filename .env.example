# Copy this file to ".env" and fill in real values. NEVER commit the real .env.
# On Heroku/Render/Railway, set these in the dashboard, not in a file.

PORT=3000

# Strong random string. Used to view /admin/stats?secret=...  (NOT "admin123")
ADMIN_SECRET=change_me_to_a_long_random_string

# Optional. Leave blank to run without a database.
# If you use it, store ONLY counters/reports — never message text.
MONGO_URI=

# Restrict who can connect the websocket (your domain). "*" = anyone.
ALLOWED_ORIGIN=*

# Keep at 0 to show the real number of people online (honest).
# Setting this fakes a higher count — not recommended.
ONLINE_BOOST=0

# ---------- AI fallback bot (the "Turing game") ----------
# Set to 1 AND provide a key to turn the bot on. Without a key it stays off.
BOT_ENABLED=0
ANTHROPIC_API_KEY=
# Cheap + fast model for casual chat. Change only if you have a reason.
BOT_MODEL=claude-haiku-4-5
# How long a user waits with no human before the bot steps in (ms).
BOT_WAIT_MS=12000

# ---------- training logs ----------
# Stores message TEXT for your Kurdish/Badini dataset.
# Leave at 0 until the in-app consent line is actually live. This reverses
# the "no message text stored" privacy stance, so turn it on deliberately.
COLLECT_LOGS=0
